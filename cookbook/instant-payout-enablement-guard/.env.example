# Model picker: openai (default, no AWS) | bedrock
MODEL_PROVIDER=openai
MODEL_ID=

# OpenAI (MODEL_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-...

# AWS Bedrock (MODEL_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# KIFF Cloud (optional)
KIFF_CLOUD_API_KEY=kiff_live_...
KIFF_CLOUD_URL=https://api.kiff.dev

# Local gate + app
KIFF_BASE_URL=http://localhost:8081
PAYOUT_APP_URL=http://localhost:8082
